[debug] [2026-03-10T15:58:05.844Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/latinbarberapp/rulesets {"name":"projects/latinbarberapp/rulesets/bda5640d-0715-4529-8088-6d07182287b8","source":{"files":[{"content":"rules_version = '2';\nservice firebase.storage {\n  match /b/{bucket}/o {\n    function currentUserPath() {\n      return /databases/(default)/documents/users/$(request.auth.uid);\n    }\n\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isAdmin() {\n      return signedIn() &&\n        (\n          request.auth.token.admin == true ||\n          (firestore.exists(currentUserPath()) && firestore.get(currentUserPath()).data.role == \"admin\")\n        );\n    }\n\n    function validImageUpload() {\n      return request.resource != null &&\n        request.resource.contentType.matches(\"image/.*\") &&\n        request.resource.size < 5 * 1024 * 1024;\n    }\n\n    match /users/{userId}/profile/{allPaths=**} {\n      allow read: if signedIn();\n      allow write: if signedIn() && request.auth.uid == userId && validImageUpload();\n    }\n\n    match /barbers/{barberId}/{allPaths=**} {\n      allow read: if signedIn();\n      allow write: if isAdmin() && validImageUpload();\n    }\n\n    match /{allPaths=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"storage.rules"}]},"createTime":"2026-03-10T15:58:05.671039Z","metadata":{"services":["firebase.storage"]}}
