[debug] [2026-03-10T15:50:19.845Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/latinbarberapp/rulesets {"name":"projects/latinbarberapp/rulesets/10af23a1-af53-42a5-b5fb-385a089e0c7d","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function currentUserPath() {\n      return /databases/$(database)/documents/users/$(request.auth.uid);\n    }\n\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isAdmin() {\n      return signedIn() &&\n        (\n          request.auth.token.admin == true ||\n          (exists(currentUserPath()) && get(currentUserPath()).data.role == \"admin\")\n        );\n    }\n\n    function isSelf(userId) {\n      return signedIn() && request.auth.uid == userId;\n    }\n\n    function keepsRole() {\n      return !(\"role\" in request.resource.data) || request.resource.data.role == resource.data.role;\n    }\n\n    function validSelfCreate(userId) {\n      return isSelf(userId) &&\n        (\n          !(\"role\" in request.resource.data) ||\n          request.resource.data.role == \"client\"\n        );\n    }\n\n    function appointmentPath(appointmentId) {\n      return /databases/$(database)/documents/appointments/$(appointmentId);\n    }\n\n    function appointmentLockPath(lockId) {\n      return /databases/$(database)/documents/appointmentLocks/$(lockId);\n    }\n\n    function clientCanCreateOwnAppointmentWithLock(appointmentId) {\n      return signedIn() &&\n        request.resource.data.customerId == request.auth.uid &&\n        request.resource.data.lockId is string &&\n        existsAfter(appointmentLockPath(request.resource.data.lockId)) &&\n        getAfter(appointmentLockPath(request.resource.data.lockId)).data.appointmentId == appointmentId &&\n        getAfter(appointmentLockPath(request.resource.data.lockId)).data.customerId == request.auth.uid &&\n        getAfter(appointmentLockPath(request.resource.data.lockId)).data.barberId == request.resource.data.barberId &&\n        getAfter(appointmentLockPath(request.resource.data.lockId)).data.date == request.resource.data.date &&\n        getAfter(appointmentLockPath(request.resource.data.lockId)).data.time == request.resource.data.time;\n    }\n\n    function clientCanCreateOwnAppointmentLock(lockId) {\n      return signedIn() &&\n        request.resource.data.customerId == request.auth.uid &&\n        request.resource.data.appointmentId is string &&\n        existsAfter(appointmentPath(request.resource.data.appointmentId)) &&\n        getAfter(appointmentPath(request.resource.data.appointmentId)).data.customerId == request.auth.uid &&\n        getAfter(appointmentPath(request.resource.data.appointmentId)).data.lockId == lockId &&\n        getAfter(appointmentPath(request.resource.data.appointmentId)).data.barberId == request.resource.data.barberId &&\n        getAfter(appointmentPath(request.resource.data.appointmentId)).data.date == request.resource.data.date &&\n        getAfter(appointmentPath(request.resource.data.appointmentId)).data.time == request.resource.data.time;\n    }\n\n    function clientOwnsLockForDelete() {\n      return signedIn() && (\n        resource.data.customerId == request.auth.uid ||\n        (\n          resource.data.appointmentId is string &&\n          exists(appointmentPath(resource.data.appointmentId)) &&\n          get(appointmentPath(resource.data.appointmentId)).data.customerId == request.auth.uid\n        )\n      );\n    }\n\n    // Admin tiene acceso total al proyecto\n    match /{document=**} {\n      allow read, write: if isAdmin();\n    }\n\n    match /users/{userId} {\n      allow create: if validSelfCreate(userId);\n      allow read: if isSelf(userId) || isAdmin();\n      allow update: if (isSelf(userId) && keepsRole()) || isAdmin();\n      allow delete: if false;\n    }\n\n    match /barbers/{barberId} {\n      allow read: if signedIn();\n      allow write: if isAdmin();\n    }\n\n    match /services/{serviceId} {\n      allow read: if signedIn();\n      allow write: if isAdmin();\n    }\n\n    match /settings/{settingId} {\n      allow read: if signedIn();\n      allow write: if isAdmin();\n    }\n\n    match /closures/{closureId} {\n      allow read: if signedIn();\n      allow write: if isAdmin();\n    }\n\n    match /appointments/{appointmentId} {\n      allow create: if isAdmin() || clientCanCreateOwnAppointmentWithLock(appointmentId);\n      allow read: if isAdmin() || (signedIn() && resource.data.customerId == request.auth.uid);\n      allow update, delete: if isAdmin() || (signedIn() && resource.data.customerId == request.auth.uid);\n    }\n\n    match /appointmentLocks/{lockId} {\n      allow read: if signedIn();\n      allow create: if isAdmin() || clientCanCreateOwnAppointmentLock(lockId);\n      allow update: if isAdmin();\n      allow delete: if isAdmin() || clientOwnsLockForDelete();\n    }\n\n    match /mail/{mailId} {\n      allow create: if signedIn();\n      allow read, update, delete: if isAdmin();\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-03-10T15:50:19.670863Z","metadata":{"services":["cloud.firestore"]}}
